---
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  labels:
    network.harvesterhci.io/clusternetwork: "{{ item.cluster_network }}"
    network.harvesterhci.io/ready: "true"
    network.harvesterhci.io/type: L2VlanNetwork
    network.harvesterhci.io/vlan-id: "{{ item.vlan_id }}"
  name: "{{ item.name }}"
  namespace: "{{ harvester_tenant_namespace }}"
{% if item.mtu is defined %}
  annotations:
    network.harvesterhci.io/mtu: "{{ item.mtu }}"
{% endif %}
spec:
  config: >-
    {"cniVersion":"0.3.1","name":"{{ item.name }}","type":"bridge","bridge":"{{ item.bridge }}","promiscMode":true,"vlan":{{ item.vlan_id | int }}{% if item.mtu is defined %},"mtu":{{ item.mtu | int }}{% endif %},"ipam":{}}
